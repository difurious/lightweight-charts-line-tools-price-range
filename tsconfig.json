// tsconfig.json
{
	"compilerOptions": {
		"target": "ES2020", 
		"module": "ESNext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"strict": true,
		"declaration": true,
		"declarationDir": "./dist/types",
		"outDir": "./dist",

		// This ensures your dist folder layout is predictable.
		"rootDir": "src",
		
		"lib": ["ES2020", "DOM"], // Explicitly include DOM for Canvas stuff
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}